# Copy to .env and fill in values

# Path to the SQLite database file (relative to the backend/ working directory)
DB_PATH=./data/xml_organizer.db

# JWT signing secret – change this to a long random string in production!
JWT_SECRET=dev-secret-change-in-production

# HTTP port the backend listens on
PORT=3001

# Allowed CORS origin (Vite dev server)
CORS_ORIGIN=http://localhost:5173
