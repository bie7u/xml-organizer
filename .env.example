# Production environment variables for Docker Compose.
# Copy this file to .env and fill in your values before running:
#
#   cp .env.example .env
#   docker compose up -d --build

# ── Required ───────────────────────────────────────────────────────────────────

# Long random secret used to sign JWT tokens.
# Generate one with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_SECURE_SECRET_BEFORE_DEPLOYMENT

# ── Optional ───────────────────────────────────────────────────────────────────

# The URL from which users access the app (used for CORS).
# Examples:
#   http://203.0.113.42       (plain IP)
#   https://my-domain.com     (custom domain with TLS termination upstream)
CORS_ORIGIN=http://localhost

# Host port to publish the app on (default: 80).
# Change to e.g. 8080 if port 80 is already in use.
APP_PORT=80
